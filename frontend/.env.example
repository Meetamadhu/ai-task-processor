# Copy to frontend/.env or frontend/.env.local (CRA only loads from this directory, not repo root).
# Values are baked in at `npm run build`. After changing env on Vercel, trigger a new deployment.
# On Vercel: leave REACT_APP_API_URL UNSET so the app calls https://<your-app>.vercel.app/api (same origin).
# Do not set it to your Render URL — that causes CORS / "Cannot reach the API". vercel.json rewrites /api → Render.
REACT_APP_API_URL=http://localhost:5000/api
