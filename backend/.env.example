# Backend .env.example
NODE_ENV=development
PORT=5000
# Set NODE_ENV=production on Render, or TRUST_PROXY=1 so rate-limit works behind X-Forwarded-For
# TRUST_PROXY=1

# Database — use 127.0.0.1 when MongoDB runs on your machine or Docker with -p 27017:27017.
# (Hostnames `mongo` / `redis` only work *inside* Docker Compose, not for `npm run dev` on the host.)
# Atlas: set MONGODB_URI; if bad auth, try MONGODB_AUTH_SOURCE=admin on Render.
MONGODB_URI=mongodb://127.0.0.1:27017/ai-task-processor
# Optional — append ?authSource=… for Atlas DB users that authenticate against admin
# MONGODB_AUTH_SOURCE=admin

# Redis — use 127.0.0.1 when Redis is local or published on port 6379 (same note as Mongo).
# REDIS_URL=redis://default:password@host:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT (required). After `cp .env.example .env`, this placeholder is enough for local dev.
# Production / shared hosts: run `openssl rand -hex 32` and set a unique value; never commit .env.
JWT_SECRET=local-dev-only-replace-with-openssl-rand-hex-32

# Frontend URL(s) for CORS — exact browser origin(s), no trailing slash.
# Multiple: FRONTEND_URL=https://app.vercel.app,https://preview-xxx.vercel.app
# Any https://*.vercel.app is also allowed. For custom domains, add FRONTEND_EXTRA_ORIGINS.
# FRONTEND_EXTRA_ORIGINS=https://www.mydomain.com
FRONTEND_URL=http://localhost:3000
