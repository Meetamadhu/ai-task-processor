# Backend .env.example
NODE_ENV=development
PORT=5000
# Set NODE_ENV=production on Render, or TRUST_PROXY=1 so rate-limit works behind X-Forwarded-For
# TRUST_PROXY=1

# Database (Atlas: set MONGODB_URI; if bad auth, try MONGODB_AUTH_SOURCE=admin on Render)
MONGODB_URI=mongodb://mongo:27017/ai-task-processor
# Optional — append ?authSource=… for Atlas DB users that authenticate against admin
# MONGODB_AUTH_SOURCE=admin

# Redis (use either REDIS_URL — e.g. on Railway — or REDIS_HOST + REDIS_PORT)
# REDIS_URL=redis://default:password@host:6379
REDIS_HOST=redis
REDIS_PORT=6379

# JWT (required — generate a long random string; never commit real values)
JWT_SECRET=

# Frontend URL(s) for CORS — exact browser origin(s), no trailing slash.
# Multiple: FRONTEND_URL=https://app.vercel.app,https://preview-xxx.vercel.app
FRONTEND_URL=http://localhost:3000
